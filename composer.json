{
  "name": "philipphermes/storage-bundle",
  "type": "symfony-bundle",
  "description": "A Symfony bundle that wraps Predis and exposes a StorageClient with essential storage operations, while still allowing direct access to the underlying client for advanced use cases.",
  "keywords": [
    "redis",
    "storage",
    "valkey"
  ],
  "readme": "/README.md",
  "license": "MIT",
  "authors": [
    {
      "name": "Philipp Hermes"
    }
  ],
  "autoload": {
    "psr-4": {
      "PhilippHermes\\StorageBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PhilippHermes\\StorageBundle\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.3",
    "predis/predis": "^3.4",
    "symfony/config": "^7.4 || ^8.0",
    "symfony/console": "^7.4 || ^8.0",
    "symfony/dependency-injection": "^7.4 || ^8.0",
    "symfony/framework-bundle": "^7.4 || ^8.0",
    "symfony/property-access": "7.4 || ^8.0",
    "symfony/serializer": "^7.4 || ^8.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.5"
  },
  "config": {
    "sort-packages": true
  }
}
